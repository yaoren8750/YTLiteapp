/*
  YTLite — English (development language).

  Keys are stable API: never rename one casually — it orphans the key in
  every translation. Comments give translator context. Positional
  placeholders (%1$@) must be preserved verbatim in translations.
*/

/* ===== Player: settings menu ===== */

/* Title of the gear menu in the player */
"player.menu.settings" = "Playback settings";
/* Menu item + picker title: video quality */
"player.menu.quality" = "Quality";
/* Menu item + picker title: audio track (dub) selection */
"player.menu.audioTrack" = "Audio track";
/* Menu item: toggles the playback statistics overlay */
"player.menu.stats" = "Stats for nerds";
/* Picker title: subtitles */
"player.menu.subtitles" = "Subtitles";

/* ===== Player: pickers ===== */

/* Subtitle picker: disables subtitles */
"player.subtitles.off" = "Off";
/* Suffix on auto-generated subtitle tracks, e.g. "English (auto)" */
"player.subtitles.autoSuffix" = " (auto)";
/* Suffix on AI auto-dubbed audio tracks, e.g. "Russian (AI)" */
"player.audioTrack.aiSuffix" = " (AI)";

/* ===== Player: status / errors ===== */

/* Status label while switching; %1$@ = quality label or track name */
"player.status.loading" = "Loading %1$@...";
/* Status label while the stream URL is being resolved */
"player.status.resolving" = "Resolving stream...";
/* Shown when a video cannot be played at all */
"player.error.playback" = "Playback failed.";
/* Shown when switching video quality failed (playback continues) */
"player.error.qualitySwitch" = "Quality switch failed.";
/* Shown when switching the audio track failed (playback continues) */
"player.error.audioTrackSwitch" = "Audio track switch failed.";

/* ===== Common ===== */

/* Subscribe button, not-subscribed state */
"common.subscribe" = "Subscribe";
/* Subscribe button, subscribed state */
"common.subscribed" = "Subscribed";
/* Generic cancel action */
"common.cancel" = "Cancel";

/* ===== Player: status ===== */

/* Status label while the player prepares the first video */
"player.status.preparing" = "Preparing video...";
/* Status label while an expired stream URL is re-resolved */
"player.status.refreshing" = "Refreshing stream...";

/* ===== Player: watch page ===== */

/* Expands the video description */
"player.description.more" = "More";
/* Collapses the video description */
"player.description.less" = "Less";
/* Action bar: share the video */
"player.action.share" = "Share";
/* Action bar: save to playlist */
"player.action.save" = "Save";
/* Action bar: download */
"player.action.download" = "Download";

/* ===== Player: comments ===== */

/* Comments section header */
"player.comments.title" = "Comments";
/* Comments header with count; %1$d = number of comments */
"player.comments.titleCount" = "Comments (%1$d)";
/* Shown while comments load */
"player.comments.loading" = "Loading comments...";
/* Shown when the comments request failed */
"player.comments.unavailable" = "Comments unavailable";
/* Shown before the watch page has loaded enough to fetch comments */
"player.comments.unavailableYet" = "Comments are unavailable yet.";
/* Button loading the next page of comments */
"player.comments.loadMore" = "Load more comments";
/* Author line of a pinned comment; %1$@ = author name */
"player.comments.pinned" = "%1$@ • Pinned";
/* Comment like count; %1$@ = formatted number */
"player.comments.likes" = "%1$@ likes";
/* Comment reply count; %1$@ = formatted number */
"player.comments.replies" = "%1$@ replies";

/* ===== Player: autoplay overlay ===== */

/* Header above the next video suggestion */
"player.autoplay.upNext" = "Up Next";
/* Starts the suggested video immediately, skipping the countdown */
"player.autoplay.playNow" = "Play now";

/* ===== Player: related section ===== */

/* Header of an unnamed autoplay queue/playlist */
"player.related.mix" = "Mix";
/* Header of the related-videos section */
"player.related.title" = "Related";
/* Status label on fatal playback failure; %1$@ = error description */
"player.error.withMessage" = "Playback error: %1$@";

/* ===== Player: speed ===== */

/* The 1x playback speed */
"player.speed.normal" = "Normal";

